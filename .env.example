# ─── LLM Provider API Keys ────────────────────────────────────────────────────
# Only the key for your chosen provider is required.
# See: notecast providers list

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── Storage ──────────────────────────────────────────────────────────────────
# SQLite database path (default: ./notes.db)
NOTES_DB_PATH=./notes.db

# LanceDB vector store path (default: derived from NOTES_DB_PATH, e.g. ./notes.lancedb)
LANCEDB_PATH=

# Embedding dimension — must match the model in use (default: 768 for nomic-embed-text)
LANCEDB_DIM=768

# ─── LLM ──────────────────────────────────────────────────────────────────────
# Force a specific provider for all LLM calls (overrides per-step config).
# Values: openai | anthropic | gemini | deepseek | ollama
LLM_PROVIDER=

# ─── Logging ──────────────────────────────────────────────────────────────────
# Log level: debug | info | warn | error  (default: info)
LOG_LEVEL=info

# Log format: json | pretty  (default: pretty in dev, json in production)
LOG_FORMAT=

# ─── CLI (remote mode) ────────────────────────────────────────────────────────
# URL of a running notecast instance. When set, the CLI talks to the
# remote server instead of opening the local database directly.
NOTES_URL=
